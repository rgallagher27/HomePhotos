{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"api:generate": "openapi-ts -i ../openapi.yaml -o src/lib/api/gen -c @hey-api/client-fetch",
		"bundle-openapi": "redocly bundle ../openapi/openapi.yaml -o ../openapi.yaml --ext yaml",
		"validate-openapi": "redocly lint ../openapi/openapi.yaml"
	},
	"devDependencies": {
		"@hey-api/client-fetch": "^0.13.1",
		"@hey-api/openapi-ts": "^0.64.0",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@redocly/cli": "^1.34.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.0.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"yaml": "^2.8.3"
	},
	"dependencies": {
		"bits-ui": "^2.16.5",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	}
}
